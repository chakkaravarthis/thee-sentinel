FROM node:18-alpine AS build
WORKDIR /app
COPY package.json .
RUN npm install --legacy-peer-deps --force
COPY public/ ./public/
COPY src/ ./src/
ENV DISABLE_ESLINT_PLUGIN=true
ENV CI=false
RUN npm run build
 
FROM nginx:alpine
COPY --from=build /app/build /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
